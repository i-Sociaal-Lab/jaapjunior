{
	"name": "@jaap/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"engines": {
		"node": "22"
	},
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"build": "tsc && bun build --compile --minify --sourcemap ./src/index.ts --outfile dist/api",
		"start": "./dist/api",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@hono/valibot-validator": "0.5.3",
		"@llamaindex/anthropic": "0.3.17",
		"@llamaindex/chroma": "0.0.29",
		"@llamaindex/google": "0.3.14",
		"@llamaindex/groq": "0.0.82",
		"@llamaindex/mistral": "0.1.15",
		"@llamaindex/openai": "0.4.10",
		"@llamaindex/readers": "3.1.14",
		"@valibot/to-json-schema": "1.3.0",
		"better-sqlite3": "11.10.0",
		"cohere-ai": "7.17.1",
		"dotenv": "16.6.1",
		"hono": "4.8.5",
		"hono-openapi": "0.4.8",
		"jose": "6.0.12",
		"llamaindex": "0.11.19",
		"valibot": "1.1.0"
	},
	"devDependencies": {
		"@types/better-sqlite3": "7.6.13",
		"typescript": "5.8.3"
	}
}
